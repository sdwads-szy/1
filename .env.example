#LLM 
OPENAI_API_KEY="your_api_key_here"
OPENAI_BASE_URL="https://api.deepseek.com" 
OPENAI_THINK_MODEL="deepseek-v4-pro" 
OPENAI_MODEL="deepseek-v4-pro"
# # 添加本地 llama-server 配置
LOCAL_OPENAI_API_KEY="111"   # 本地不需要真实密钥，但代码可能要求非空
LOCAL_OPENAI_BASE_URL="http://localhost:3002/completion"   # completion 端点（llm.py 用）
LOCAL_OPENAI_V1_URL="http://localhost:3002/v1"             # OpenAI 兼容端点（picoagents 用）
LOCAL_OPENAI_MODEL="Qwopus3.5-4B-coder-Q4_K_M.gguf"
LOCAL_CTX_SIZE=32768           # 模型上下文窗口大小
LOCAL_TIMEOUT=600              # 本地模型推理超时（秒）
LOCAL_MAX_TOKENS=4096          # 单次输出上限
# Server
PORT="3000"

# MySQL Database
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="your_db_password"
DB_NAME="testdb"

# ── RAG 知识库配置 ───────────────────────
RAG_EMBEDDING_MODEL="Qwen/Qwen3-Embedding-4B"   # 向量嵌入模型
RAG_RERANKER_MODEL="Qwen/Qwen3-Reranker-4B"        # 重排序模型（None=禁用）
RAG_CHUNK_SIZE=800           # 文档分块大小
RAG_CHUNK_OVERLAP=80         # 分块重叠
RAG_TABLE="knowledge"        # 检索主表（聚类后）
RAG_BUILD_TABLE="knowledge_base"  # 构建中间表（聚类前）
#redis
REDIS_URL=redis://localhost:6379/0
RAG_CACHE_TTL=86400