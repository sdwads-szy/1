# =============================================================================
# Agent 多智能体代码生成系统 — .gitignore
# =============================================================================

# ── 敏感信息（含 API Key，绝对不提交）──
.env
.env.local
.env.development
.env.production

# ── Python 缓存/虚拟环境 ──
__pycache__/
*.pyc
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── 产物目录（提交源码，排除敏感/运行时文件）──
work/project/node_modules/
work/project/.env
work/project/.env.development
work/project/.env.production
work/project/.esbuild-check.js
work/project/.esbuild-pre-check.js
work/project/package-lock.json
work/project/.meta/

# ── 运行时记忆（包含 API 日志/会话记录/禁令/真理/快照，不提交）──
Memory/
doc/RESULT_ANALYSIS.md

# ── Node（产物内的 node_modules，太大）──
node_modules/
package-lock.json

# ── 向量数据库（二进制大文件，可重建）──
knowledge/

# ── 旧产物清理 ──
work/project/task/task_202*.json
!work/project/task/task_20260629_202235.json
work/project/report/
work/project/.meta/
work/project/test/test_tasks_202*.json
!work/project/test/test_tasks_20260629_213816.json

# ── 临时文件 ──
*.tmp
*.bak
*.swp
*.swo
*~

# ── IDE ──
.vscode/
.idea/

# ── OS ──
.DS_Store
Thumbs.db

# ── Claude ──
.claude/
