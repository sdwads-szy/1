# =============================================================================
# Agent 多智能体代码生成系统 — .gitignore
# =============================================================================

# ── 敏感信息（含 API Key，绝对不提交）──
.env
.env.local
.env.development
.env.production

# ── Python 缓存/虚拟环境 ──
__pycache__/
*.pyc
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/

# ── Node（产物内的 node_modules，太大）──
node_modules/
package-lock.json

# ── 向量数据库（二进制大文件，可重建）──
knowledge/

# ── 运行时记忆（包含 API 日志/会话记录，可重建）──
Memory/chat_sessions/
Memory/test_failure/
Memory/source_failure/
Memory/test_logs/
Memory/truths/
Memory/snapshots/
Memory/logs/
Memory/agent_logs/

# ── 旧产物清理 ──
work/project/task/task_202*.json
!work/project/task/task_20260629_202235.json
work/project/report/
work/project/.meta/
work/project/test/test_tasks_202*.json
!work/project/test/test_tasks_20260629_213816.json

# ── 临时文件 ──
*.tmp
*.bak
*.swp
*.swo
*~

# ── IDE ──
.vscode/
.idea/

# ── OS ──
.DS_Store
Thumbs.db

# ── Claude ──
.claude/
