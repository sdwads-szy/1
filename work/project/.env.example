# ══ 服务器 ══
# 服务端口
PORT=3000
# 运行环境 (development | production)
NODE_ENV=development
# 日志级别 (error | warn | info | debug)
LOG_LEVEL=info
# CORS 允许的源
CORS_ORIGIN=http://localhost:5173

# ══ 数据库 ══
# 数据库主机地址
DB_HOST=localhost
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=your_db_password
# 数据库名称
DB_NAME=testdb

# ══ Redis ══
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0
# Redis 主机
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379

# ══ JWT 鉴权 ══
# JWT 签名密钥
JWT_SECRET=change-me-in-production
# JWT 过期时间
JWT_EXPIRES_IN=15m
# JWT 刷新密钥
JWT_REFRESH_SECRET=change-me-refresh-in-production
# JWT 刷新过期时间
JWT_REFRESH_EXPIRES_IN=7d

# ══ 加密 ══
# AES 加密密钥 (32字节)
ENCRYPTION_KEY=change-me-32-bytes-key-here!!

# ══ 文件服务 ══
# 文件服务基础 URL (末尾无斜杠)
FILE_BASE_URL=
# 文件模式 (mock | real)
FILE_MODE=mock

# ══ 短信服务 ══
# 短信模式 (mock | real)
SMS_MODE=mock
# -- MODE=real 需填 --
# 短信 API Key
SMS_API_KEY=
# 短信 API Secret
SMS_API_SECRET=
# 短信签名
SMS_SIGN_NAME=
# 短信模板编码
SMS_TEMPLATE_CODE=

# ══ 支付服务 ══
# 支付模式 (mock | real)
PAYMENT_MODE=mock
# 支付 API Key（通用）
PAYMENT_API_KEY=
# -- MODE=real 需填 --
# 微信支付 App ID
WECHAT_PAY_APP_ID=
# 微信支付商户号
WECHAT_PAY_MCH_ID=
# 微信支付 API Key
WECHAT_PAY_API_KEY=
# 微信支付回调 URL
WECHAT_PAY_NOTIFY_URL=
# 支付宝 App ID
ALIPAY_APP_ID=
# 支付宝私钥
ALIPAY_PRIVATE_KEY=
# 支付宝回调 URL
ALIPAY_NOTIFY_URL=

# ══ 微信开放平台 ══
# 微信 OAuth 模式 (mock | real)
WECHAT_OAUTH_MODE=mock
# -- MODE=real 需填 --
# 微信 App ID
WECHAT_APP_ID=
# 微信 App Secret
WECHAT_APP_SECRET=

# ══ 对象存储 OSS ══
# OSS 模式 (mock | real)
OSS_MODE=mock
# -- MODE=real 需填 --
# OSS 区域
OSS_REGION=
# OSS Access Key
OSS_ACCESS_KEY=
# OSS Secret Key
OSS_SECRET_KEY=
# OSS Bucket 名称
OSS_BUCKET=

# ══ Elasticsearch ══
# ES 模式 (mock | real)
ES_MODE=mock
# -- MODE=real 需填 --
# ES 主机地址
ES_HOST=
# ES API Key
ES_API_KEY=

# ══ 邮件服务 ══
# 邮件模式 (mock | real)
MAIL_MODE=mock
# -- MODE=real 需填 --
# SMTP 主机
MAIL_HOST=
# SMTP 端口
MAIL_PORT=587
# SMTP 用户名
MAIL_USER=
# SMTP 密码
MAIL_PASS=
# SMTP 主机（代码 process.env.SMTP_HOST）
SMTP_HOST=
# SMTP 端口（代码 process.env.SMTP_PORT）
SMTP_PORT=587
# SMTP 用户名（代码 process.env.SMTP_USER）
SMTP_USER=
# SMTP 密码（代码 process.env.SMTP_PASS）
SMTP_PASS=

# ══ 物流服务 ══
# 物流模式 (mock | real)
LOGISTICS_MODE=mock
# -- MODE=real 需填 --
# 物流 API Key
LOGISTICS_API_KEY=
# 物流 API Secret
LOGISTICS_API_SECRET=

# ══ 敏感词过滤 ══
# 敏感词模式 (mock | real)
SENSITIVE_WORD_MODE=mock
# -- MODE=real 需填 --
# 敏感词 API 地址
SENSITIVE_WORD_API_URL=
# 敏感词 API Key
SENSITIVE_WORD_API_KEY=

# ══ 自动注入 ══
# 邮件模式 (mock | real) — 代码 process.env.EMAIL_MODE
EMAIL_MODE=mock
# Snowflake Worker ID
WORKER_ID=1
