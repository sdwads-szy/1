# 服务器端口
PORT=3000

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Redis 连接地址 (格式: redis://host:port/db)
REDIS_URL=redis://localhost:6379/0

# JWT 密钥 (生产环境必须更换为随机字符串)
JWT_SECRET=your_jwt_secret
# JWT 刷新密钥
JWT_REFRESH_SECRET=your_jwt_refresh_secret
# JWT 过期时间 (格式: 数字+单位, 如 7d / 24h / 60m)
JWT_EXPIRES_IN=7d

# 加密密钥 (必须为 32 字符)
ENCRYPTION_KEY=your_encryption_key_32chars

# 日志级别: error / warn / info / debug
LOG_LEVEL=info

# CORS 允许来源 (* 表示所有, 生产环境改为具体域名)
CORS_ORIGIN=*

# 运行环境: development / production
NODE_ENV=development

# Auto-injected by integrator (6 vars from code scan)
ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD=your_admin_password_here
ADMIN_USERNAME=your_admin_username_here
ELASTICSEARCH_HOST=your_elasticsearch_host_here
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret_here
SNOWFLAKE_WORKER_ID=your_snowflake_worker_id_here
