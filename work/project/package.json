{
  "name": "star-chain-mall",
  "version": "1.0.0",
  "description": "星链商城 (StarChain Mall) — 多商户电商平台",
  "private": true,
  "scripts": {
    "db": "node scripts/init-db.js",
    "seed": "node scripts/init-db.js --seed-only",
    "backend": "node app.js",
    "frontend": "npx vite",
    "test": "jest"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.23.0",
    "redis": "^4.7.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.4",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "axios": "^1.7.7",
    "babel-jest": "^29.7.0",
    "echarts": "^5.5.1",
    "element-plus": "^2.8.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "pinia": "^2.2.2",
    "supertest": "^7.0.0",
    "vite": "^5.4.6",
    "vue": "^3.5.4",
    "vue-router": "^4.4.3"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/test/**/*.test.js"
    ],
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.vue$": "@vue/vue3-jest",
      "^.+\\.js$": "babel-jest"
    },
    "forceExit": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
